    {
        "id": "9dbccfe5266e29c0",
        "type": "function",
        "z": "4a22ae1c4437b1c9",
        "name": "function 1",
        "func": "// Parsear el payload: zona:tipo:estado:detalle\nconst partes = msg.payload.split(':');\nconst zona = partes[0] || '?';\nconst tipo = partes[1] || '?';\nconst estado = partes[2] || '?';\nconst detalle = partes.slice(3).join(':') || '';\n\nconst ahora = new Date().toLocaleTimeString();\n\n// Indicador visual según el estado\nlet icono = '';\nif (estado === 'CONFIRMADA') {\n    icono = '🔴';\n} else if (estado === 'FALSO_POSITIVO') {\n    icono = '⚪';\n}\n\nmsg.payload = {\n    indicador: icono,\n    hora: ahora,\n    zona: zona,\n    tipo: tipo,\n    estado: estado,\n    detalle: detalle\n};\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],

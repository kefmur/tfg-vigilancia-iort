    {
        "id": "a11ea6239dd9cef5",
        "type": "function",
        "z": "4a22ae1c4437b1c9",
        "name": "function 3",
        "func": "// Recuperar contadores guardados (o iniciar a 0)\nlet total = context.get('total') || 0;\nlet confirmadas = context.get('confirmadas') || 0;\nlet falsos = context.get('falsos') || 0;\n\n// Incrementar según el estado\ntotal += 1;\nif (msg.payload.estado === 'CONFIRMADA') {\n    confirmadas += 1;\n} else if (msg.payload.estado === 'FALSO_POSITIVO') {\n    falsos += 1;\n}\n\n// Guardar de nuevo\ncontext.set('total', total);\ncontext.set('confirmadas', confirmadas);\ncontext.set('falsos', falsos);\n\n// Texto para mostrar\nmsg.payload = `Total: ${total}  |  Confirmadas: ${confirmadas}  |  Falsos positivos: ${falsos}`;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,

    {
        "id": "4ccc16a27dc70fa2",
        "type": "ui-template",
        "z": "4a22ae1c4437b1c9",
        "group": "7e377ca2cde66741",
        "page": "",
        "ui": "",
        "name": "Estado robot con color",
        "order": 2,
        "width": 0,
        "height": 0,
        "head": "",
        "format": "<template>\n    <div style=\"padding: 10px; text-align: center;\">\n        <div style=\"font-size: 14px; color: #888; margin-bottom: 8px;\">\n            Estado del robot\n        </div>\n        <div :style=\"estiloEstado\" style=\"font-size: 22px; font-weight: bold; padding: 12px; border-radius: 8px;\">\n            {{ estadoActual }}\n        </div>\n    </div>\n</template>\n\n<script>\nexport default {\n    data() {\n        return {\n            estadoActual: 'CONECTANDO...'\n        }\n    },\n    computed: {\n        estiloEstado() {\n            const colores = {\n                'PATRULLANDO':    { color: '#fff', background: '#28a745' },\n                'INVESTIGANDO':   { color: '#fff', background: '#fd7e14' },\n                'INSPECCIONANDO': { color: '#fff', background: '#007bff' },\n                'VOLVIENDO':      { color: '#fff', background: '#6c757d' }\n            };\n            return colores[this.estadoActual] || { color: '#000', background: '#e0e0e0' };\n        }\n    },\n    watch: {\n        msg: function() {\n            if (this.msg && this.msg.payload) {\n                this.estadoActual = this.msg.payload;\n            }\n        }\n    }\n}\n</script>",
